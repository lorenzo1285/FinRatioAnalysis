{
  "name": "finratio_company_snapshot",
  "description": "Aggregate one-call fundamentals snapshot: returns every ratio family (return, efficiency, leverage, liquidity, ccc, valuation_growth, historical_valuation, z_score, capm, wacc) for a ticker in a single response. Sections that fail individually report a per-section error without aborting the whole response.",
  "annotations": {
    "readOnlyHint": true,
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": true
  },
  "input": {
    "type": "object",
    "properties": {
      "ticker": {
        "type": "string",
        "minLength": 1,
        "maxLength": 10,
        "pattern": "^[A-Z0-9.\\-]+$",
        "description": "Upper-case ticker symbol (e.g., AAPL, BRK-B)."
      },
      "freq": {
        "type": "string",
        "enum": [
          "yearly",
          "quarterly"
        ],
        "default": "yearly"
      },
      "response_format": {
        "type": "string",
        "enum": [
          "json",
          "markdown"
        ],
        "default": "json"
      }
    },
    "required": [
      "ticker"
    ],
    "additionalProperties": false
  },
